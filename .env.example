# Copy this file to .env and fill in your values.
# Never commit .env to GitHub.

# ── chatbot backend (chat_proxy.py) ──────────────────────────
LLM_API_KEY=your-anthropic-api-key-here
LLM_API_URL=https://api.anthropic.com/v1/messages

# ── React frontend ────────────────────────────────────────────
# Set this to your deployed chat_proxy URL once you push to Render/Railway.
# Leave blank to use the default http://localhost:5002/chat during development.
REACT_APP_CHAT_API=http://localhost:5002/chat
